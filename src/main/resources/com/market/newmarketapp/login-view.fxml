<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<GridPane alignment="CENTER" hgap="20" prefHeight="339.0" prefWidth="390.0" styleClass="main-container" stylesheets="@css/style.css" vgap="20" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.market.newmarketapp.LoginController">

    <!-- Titolo -->
    <Label styleClass="title-label" text="Login" GridPane.columnIndex="1" GridPane.columnSpan="2" />

    <!-- Username -->
    <Label prefHeight="16.0" prefWidth="85.0" styleClass="form-label" text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
    <TextField fx:id="emailField" promptText="Inserisci il tuo username" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="1" />

    <!-- Password -->
    <Label styleClass="form-label" text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
    <PasswordField fx:id="passwordField" promptText="Inserisci la tua password" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="2" />

    <!-- Pulsante Login -->
    <Button fx:id="loginButton" onAction="#handleLoginButton" styleClass="primary-button" text="Login" GridPane.columnIndex="1" GridPane.rowIndex="3" />

    <!-- Messaggio di errore -->
    <Label fx:id="errorLabel" styleClass="error-message" text="Credenziali errate!" visible="false" GridPane.columnSpan="2" GridPane.rowIndex="4" />

    <!-- Link di registrazione -->
    <Hyperlink fx:id="link" styleClass="" text="Non hai un account? Registrati." GridPane.columnSpan="2" GridPane.rowIndex="5" />

    <!-- Pulsante Back -->
    <Button onAction="#onBackButton" prefHeight="38.0" prefWidth="88.0" styleClass="secondary-button" text="Indietro" GridPane.columnSpan="2" />

    <!-- Colonne e righe -->
    <columnConstraints>
        <ColumnConstraints />
        <ColumnConstraints />
        <ColumnConstraints />
    </columnConstraints>
    <rowConstraints>
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
      <RowConstraints />
    </rowConstraints>
</GridPane>
