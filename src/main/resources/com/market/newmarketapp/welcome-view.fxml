<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="401.0" prefWidth="617.0" styleClass="main-container" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.market.newmarketapp.WelcomeController">

   <!-- Sezione titolo -->
   <HBox alignment="CENTER" prefHeight="77.0" prefWidth="760.0" styleClass="title-container">
      <Text styleClass="title-label" text="Benvenuto nella nuova app di marketing!" textAlignment="CENTER" />
   </HBox>

   <!-- Sezione immagine e pulsanti -->
   <VBox alignment="CENTER" prefHeight="280.0" prefWidth="760.0" spacing="30.0" styleClass="content-container">
      <!-- Immagine dell'app -->
      <ImageView fx:id="iconApp" fitHeight="200.0" fitWidth="455.0" pickOnBounds="true" preserveRatio="true" styleClass="app-icon">
         <Image url="@icon-app.png" />
      </ImageView>

      <!-- Pulsanti Registrati e Login -->
      <HBox alignment="CENTER" prefHeight="77.0" prefWidth="760.0" spacing="20.0" styleClass="buttons-container">
         <Button fx:id="registerButton" onAction="#goToRegister" styleClass="primary-button" text="Registrati" />
         <Button fx:id="loginButton" onAction="#goToLogin" styleClass="secondary-button" text="Login" />
      </HBox>
   </VBox>

</VBox>
