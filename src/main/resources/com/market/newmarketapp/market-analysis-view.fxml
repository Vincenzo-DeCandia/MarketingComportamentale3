<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="15" styleClass="main-container" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.market.newmarketapp.adminScenes.AnalyzeUserController">
    <HBox prefHeight="32.0" prefWidth="624.0">
        <Button mnemonicParsing="false" onAction="#onBackButton" prefHeight="38.0" prefWidth="96.0" styleClass="secondary-button" text="Indietro" />

        <!-- Header -->
        <HBox alignment="CENTER" prefHeight="38.0" prefWidth="454.0" spacing="10" styleClass="">
            <Label prefHeight="27.0" prefWidth="157.0" styleClass="header-title" text="Analisi utenti" />
        </HBox>
    </HBox>
   <HBox prefHeight="24.0" prefWidth="624.0">
      <children>
         <HBox prefHeight="34.0" prefWidth="168.0" />
         <HBox prefHeight="34.0" prefWidth="206.0">
            <children>
               <ComboBox fx:id="boxSearchUser" prefHeight="34.0" prefWidth="187.0" promptText="Ricerca utenti" styleClass="search-box" >
               </ComboBox>
            </children>
         </HBox>
         <HBox prefHeight="46.0" prefWidth="68.0">
            <children>
               <TextField fx:id="counterField" prefHeight="46.0" prefWidth="54.0" />
            </children>
         </HBox>
         <HBox prefHeight="66.0" prefWidth="90.0">
            <children>
               <Button mnemonicParsing="false" onAction="#handleSearchUserButton" prefHeight="61.0" prefWidth="90.0" styleClass="search-button" text="Ricerca" />
            </children>
         </HBox>
      </children>
   </HBox>

    <!-- TableView Section -->
    <VBox alignment="TOP_CENTER" spacing="10" styleClass="table-section">
        <TableView fx:id="userTable" styleClass="user-table">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" />
                <TableColumn fx:id="nameColumn" prefWidth="150" text="Name" />
                <TableColumn fx:id="surnameColumn" prefWidth="150" text="Surname" />
                <TableColumn fx:id="categoryColumn" prefWidth="200" text="Category" />
            </columns>
        </TableView>
    </VBox>

    <!-- Action Buttons Section -->
    <HBox alignment="CENTER" spacing="15" styleClass="button-section">
        <Button fx:id="buttonAddOffer" onAction="#handleButtonAddOffer" styleClass="primary-button" text="Aggiungi offerta" />
    </HBox>
</VBox>
