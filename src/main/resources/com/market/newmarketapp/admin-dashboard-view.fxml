<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" styleClass="main-container" stylesheets="@css/dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.market.newmarketapp.adminScenes.AdminDashboardController">

    <!-- Menu laterale -->
    <left>
        <VBox prefHeight="600.0" prefWidth="179.0" styleClass="sidebar">
            <ImageView fitHeight="100" fitWidth="100">
                <Image url="@user-icon.png" />
            </ImageView>
            <Button onAction="#goToProfile" styleClass="sidebar-button" text="Profilo" />
            <Button onAction="#goToProductManagement" styleClass="sidebar-button" text="Gestione Prodotti" />
            <Button onAction="#goToUserMarketAnalysis" styleClass="sidebar-button" text="Analisi Mercato" />
            <Button onAction="#onLogoutButton" styleClass="logout-button" text="Logout" />
        </VBox>
    </left>

    <!-- Contenuto principale -->
    <center>
        <VBox prefHeight="601.0" prefWidth="619.0" styleClass="content">
            <!-- Titolo della pagina -->
            <Text styleClass="dashboard-title" text="Benvenuto nella Dashboard" />

            <!-- Area dinamica per i contenuti -->
            <VBox fx:id="dynamicContent" styleClass="dynamic-content">
                <LineChart fx:id="moneyLineChart">
                    <xAxis>
                        <CategoryAxis side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT" />
                    </yAxis>
                </LineChart>
            </VBox>
        </VBox>
    </center>
</BorderPane>
