<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500" prefWidth="800" style="-fx-padding: 20; -fx-background-color: #f7f9fc;" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.market.newmarketapp.adminScenes.ProductManagementController">

    <!-- Titolo -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10;">
            <VBox prefHeight="38.0" prefWidth="257.0">
               <children>
                      <Button mnemonicParsing="false" onAction="#handleBackButton" styleClass="secondary-button" text="Indietro" textFill="#2859d3" />
               </children>
            </VBox>
                <Label styleClass="title-label" text="Gestione Prodotti" />
            </HBox>
            <!-- Filtri -->
            <HBox alignment="CENTER" spacing="15" style="-fx-padding: 10;">
                <TextField fx:id="searchByNameTextField" promptText="Cerca per Nome" style="-fx-font-size: 14px; -fx-padding: 10; -fx-border-color: #3498db; -fx-border-radius: 5; -fx-background-color: white;" />
                <Button onAction="#handleSearchByName" style="-fx-font-size: 14px; -fx-padding: 8 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Cerca" />
                <TextField fx:id="searchByCategoryTextField" promptText="Cerca per Categoria" style="-fx-font-size: 14px; -fx-padding: 10; -fx-border-color: #3498db; -fx-border-radius: 5; -fx-background-color: white;" />
                <Button onAction="#handleSearchByCategory" style="-fx-font-size: 14px; -fx-padding: 8 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-border-radius: 5; -fx-cursor: hand;" text="Cerca" />
            </HBox>
        </VBox>
    </top>

    <!-- Corpo -->
    <center>
        <SplitPane dividerPositions="0.5" style="-fx-background-color: #ecf0f1; -fx-border-radius: 10;">
            <!-- Lista Prodotti -->
            <VBox spacing="15" style="-fx-padding: 10;">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Lista Prodotti" />
                <ListView fx:id="productListView" prefHeight="300" style="-fx-border-color: #3498db; -fx-border-radius: 5; -fx-background-color: white;" />
            </VBox>

            <!-- Dettagli del Prodotto -->
            <VBox spacing="15" style="-fx-padding: 10;">
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Dettagli Prodotto" />
                <GridPane hgap="10" vgap="10">
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #34495e;" text="ID Prodotto:" />
                    <TextField fx:id="productIdField" editable="false" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #34495e;" text="Nome Prodotto:" />
                    <TextField fx:id="productNameField" editable="false" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #34495e;" text="Prezzo:" />
                    <TextField fx:id="productPriceField" editable="false" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
                    <Label style="-fx-font-size: 14px; -fx-text-fill: #34495e;" text="Descrizione:" />
                    <TextArea fx:id="productDescriptionField" editable="false" prefHeight="208.0" prefWidth="355.0" style="-fx-background-color: #ecf0f1; -fx-border-color: #bdc3c7; -fx-border-radius: 5;" wrapText="true" />
                    <columnConstraints>
                        <ColumnConstraints halignment="LEFT" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints valignment="CENTER" />
                    </rowConstraints>
                </GridPane>
            </VBox>
        </SplitPane>
    </center>

    <!-- Pulsanti -->
    <bottom>
        <HBox alignment="CENTER" spacing="15" style="-fx-padding: 20;">
            <Button fx:id="insertProductButton" onAction="#handleInsertButton" styleClass="button-add" text="Inserisci Prodotto" />
            <Button fx:id="modifyProductButton" disable="true" onAction="#handleModifyButton" styleClass="button-modify" text="Modifica Prodotto" />
            <Button fx:id="deleteProductButton" disable="true" onAction="#handleDeleteProduct" styleClass="button-decrement" text="Elimina Prodotto" />
        </HBox>
    </bottom>

</BorderPane>
